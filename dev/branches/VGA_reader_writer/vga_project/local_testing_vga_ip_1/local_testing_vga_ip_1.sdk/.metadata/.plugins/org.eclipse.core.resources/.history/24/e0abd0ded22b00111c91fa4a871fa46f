/* ===================== KEYBOARD HELPERS ===================== */
char poll_keyboard() {
    volatile uint32_t *ps2_gpio = (uint32_t *)PS2_USER_DATA_ADDR; // gpio 2
    uint32_t status = *ps2_gpio; // Read Channel 1 (Inputs) - fifo_en


    if (status == 0x100) {
		xil_printf("status: 0x%08x\r\n", status);
    }


    // Bit 8 is the 'Empty' flag
    bool empty = (status >> 8) & 0x1; // fifo empty

    if (!empty) {

        // We must pop the FIFO FIRST to load the character into read_data
        *(ps2_gpio + 2) = 1;

        // Wait a few cycles to ensure the hardware updates read_data
        for (volatile int i = 0; i < 100; i++);

        *(ps2_gpio + 2) = 0;

        // Now read the updated status which contains the popped character
        status = *ps2_gpio;
        return (char)(status & 0xFF);
    }
    return 0;
}

